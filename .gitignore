# =======================================================================
# Dynamic Pricing — gitignore
# =======================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
# .venv bare = symlink to project-root .venv (worktree workflow)
.venv
venv/
env/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- Data (raw CSV không commit, file lớn) ---
data/raw/*.csv
data/raw/*.parquet
data/processed/*.parquet
data/processed/*.csv
# Exception: commit processed features cho Streamlit Cloud deploy
!data/processed/features.parquet

# --- Model artifacts (binary, không cần version) ---
models/*.joblib
models/*.pkl
# Exception: commit trained models cho Streamlit Cloud deploy
!models/forecast_*.joblib
!models/demand_*.joblib

# --- Notebook exports ---
notebooks/*.html
notebooks/*.pdf
# Exception: commit notebook HTMLs cho Streamlit multi-page app
!notebooks/01_eda.html
!notebooks/02_features.html
!notebooks/03_forecast.html
!notebooks/04_demand_curve.html
!notebooks/05_model_comparison.html

# --- Claude Code worktree state ---
.claude/

# --- Streamlit cache ---
.streamlit/secrets.toml

# --- IDE / OS ---
.DS_Store
.vscode/
.idea/

# --- Logs ---
*.log
